<Window x:Class="AncestorsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ancestors" Height="900" Width="1440"
        MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F8"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F5F8"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelMutedBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#172033"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#637083"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DEE8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF1FF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318"/>

        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF4FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B9CBF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DDE9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="#F0B8B2"/>
            <Setter Property="Background" Value="#FFF7F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFE9E6"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E89A91"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFDAD5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,5"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,18,0,6"/>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FBFCFE"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Ancestors" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Stammbaum bearbeiten, prüfen und sichern" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Neu" Click="NewTree_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Öffnen" Click="LoadTree_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Speichern" Click="SaveTree_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,18,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="392"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Background="{StaticResource PanelMutedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Baumansicht" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock x:Name="TreeSummaryText" Text="0 Personen | 0 Generationen" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="FocusSelectionButton"
                                    Content="Zur Auswahl"
                                    Click="FocusSelection_Click"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="TreeScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#F7F9FC">
                        <Canvas x:Name="TreeCanvas" Background="#F7F9FC" MinWidth="1040" MinHeight="680"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Background="{StaticResource PanelMutedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Details" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Auswahl bearbeiten und neue Personen anlegen" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="#C8D8FF" BorderThickness="1" CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock x:Name="SelectedTitleText" Text="Keine Auswahl" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SelectedSubtitleText" Text="Wählen Sie eine Person im Baum aus." FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SelectedIdText" Text="" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Aktionen" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddChildButton" Grid.Column="0" Content="Kind hinzufügen" Click="AddChild_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,6,0"/>
                                <Button x:Name="AddSiblingButton" Grid.Column="1" Content="Geschwister" Click="AddSibling_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="6,0,0,0"/>
                            </Grid>
                            <Button x:Name="DeletePersonButton" Content="Person löschen" Click="DeletePerson_Click" Style="{StaticResource DangerButtonStyle}" Margin="0,10,0,0"/>

                            <TextBlock Text="Person" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Vorname" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="FirstNameBox" TextChanged="Metadata_TextChanged"/>

                            <TextBlock Text="Nachname" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="LastNameBox" TextChanged="Metadata_TextChanged"/>

                            <TextBlock Text="Geburtsdatum" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="BirthDateBox" TextChanged="Metadata_TextChanged"/>

                            <TextBlock Text="Sterbedatum" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DeathDateBox" TextChanged="Metadata_TextChanged"/>

                            <TextBlock x:Name="DateValidationText"
                                       Text="Datum bitte als TT.MM.JJJJ eingeben."
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12"
                                       Visibility="Collapsed"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Geburtsort" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="BirthPlaceBox" TextChanged="Metadata_TextChanged"/>

                            <TextBlock Text="Notizen" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NotesBox"
                                     Height="150"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     TextChanged="Metadata_TextChanged"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Bereit." VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                <TextBlock x:Name="DirtyMarkerText" Grid.Column="1" Text="Gespeichert" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
