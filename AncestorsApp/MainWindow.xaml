<Window x:Class="AncestorsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ribbon="clr-namespace:System.Windows.Controls.Ribbon;assembly=System.Windows.Controls.Ribbon"
        Title="Stammbaum Editor" Height="860" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <ribbon:Ribbon x:Name="MainRibbon" DockPanel.Dock="Top" Title="Stammbaum Editor">
            <ribbon:RibbonTab Header="Datei">
                <ribbon:RibbonGroup Header="Projekt">
                    <ribbon:RibbonButton Label="Neu" Click="NewTree_Click" LargeImageSource="{x:Null}" />
                    <ribbon:RibbonButton Label="Öffnen" Click="LoadTree_Click" LargeImageSource="{x:Null}" />
                    <ribbon:RibbonButton Label="Speichern" Click="SaveTree_Click" LargeImageSource="{x:Null}" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>
            <ribbon:RibbonTab Header="Bearbeiten">
                <ribbon:RibbonGroup Header="Personen">
                    <ribbon:RibbonButton Label="Kind hinzufügen" Click="AddChild_Click" />
                    <ribbon:RibbonButton Label="Geschwister hinzufügen" Click="AddSibling_Click" />
                    <ribbon:RibbonButton Label="Person löschen" Click="DeletePerson_Click" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>
        </ribbon:Ribbon>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="TreeCanvas" Background="#FAFAFA" MinWidth="1000" MinHeight="700"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Margin="8" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Background="White">
                <StackPanel>
                    <TextBlock Text="Personendaten" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Vorname"/>
                    <TextBox x:Name="FirstNameBox" Margin="0,4,0,10" TextChanged="Metadata_TextChanged"/>

                    <TextBlock Text="Nachname"/>
                    <TextBox x:Name="LastNameBox" Margin="0,4,0,10" TextChanged="Metadata_TextChanged"/>

                    <TextBlock Text="Geburtsdatum (TT.MM.JJJJ)"/>
                    <TextBox x:Name="BirthDateBox" Margin="0,4,0,10" TextChanged="Metadata_TextChanged"/>

                    <TextBlock Text="Sterbedatum (optional)"/>
                    <TextBox x:Name="DeathDateBox" Margin="0,4,0,10" TextChanged="Metadata_TextChanged"/>

                    <TextBlock Text="Geburtsort"/>
                    <TextBox x:Name="BirthPlaceBox" Margin="0,4,0,10" TextChanged="Metadata_TextChanged"/>

                    <TextBlock Text="Notizen"/>
                    <TextBox x:Name="NotesBox" Margin="0,4,0,12" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextChanged="Metadata_TextChanged"/>

                    <TextBlock x:Name="StatusText" Text="Keine Person ausgewählt." Foreground="#555"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
